{
  "name": "playwright-cli",
  "version": "0.1.0",
  "description": "Playwright CLI with built-in cookie/localStorage injection from Chrome profiles",
  "type": "module",
  "bin": {
    "playwright-cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean --target node20",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  }
}
